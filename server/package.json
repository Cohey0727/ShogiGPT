{
  "name": "@shogigpt/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec 'bun src/index.ts'",
    "start": "bun src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -b --noEmit && oxlint && prettier --write . --log-level warn",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "drizzle-kit": "^0.31.10",
    "nodemon": "^3.1.14",
    "oxlint": "^1.60.0",
    "prettier": "3.8.3",
    "typescript": "~6.0.3"
  }
}
